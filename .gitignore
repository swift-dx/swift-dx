# SwiftPM
.build/
.build-*/
.swiftpm/
Packages/
Package.pins

# Lockfiles. swift-dx ships as a set of libraries: consumers resolve fresh
# against our Package.swift version ranges, so we do not pin transitives
# for them. Examples is a contributor sandbox, same posture. Integrity
# (under Tooling/) is a standalone publishable tool whose deterministic
# build matters, so its Package.resolved IS tracked.
/Package.resolved
/Examples/Package.resolved

# Xcode (generated when opening Package.swift in Xcode)
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
*.xcuserstate
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.hmap

